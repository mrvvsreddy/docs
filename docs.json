{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Maedo",
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#1d4ed8"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Webchat",
            "pages": [
              "agents/introduction",
              "agents/quickstart",
              "agents/configure"
            ]
          },
          {
            "group": "Features",
            "pages": []
          },
          {
            "group": "Core Capabilities",
            "pages": [
              "build/encrypted-memory",
              "build/progressive-data-collection",
              "build/multi-channel-presence"
            ]
          }
        ]
      },
      {
        "tab": "AI Tools",
        "groups": [
          {
            "group": "AI Extensions",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog/index"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/images/logo-bg-white.png",
    "dark": "/images/logo-bg-black.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Homepage",
        "href": "https://maedo.in"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/NYaQz6rZ"
      },
      {
        "label": "Log In",
        "href": "https://app.maedo.in/auth/signin"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign Up",
      "href": "https://app.maedo.in/auth/signup"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/useMaedo",
      "linkedin": "https://www.linkedin.com/company/maedo"
    }
  }
}